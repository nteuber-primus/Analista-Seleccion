{
  "name": "cv-reviewer-web",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env server.js",
    "dev": "node --env-file=.env --watch server.js",
    "postinstall": "node -e \"const fs=require('fs');const d='node_modules/node-ensure';fs.mkdirSync(d,{recursive:true});fs.writeFileSync(d+'/index.js','module.exports=function(d,c){c();}');fs.writeFileSync(d+'/package.json',JSON.stringify({name:'node-ensure',version:'0.0.0',main:'index.js'}));\""
  },
  "dependencies": {
    "express": "^4.19.2",
    "mammoth": "^1.9.0",
    "pdf-parse": "1.1.1"
  }
}
